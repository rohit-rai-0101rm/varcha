# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/varcha?retryWrites=true&w=majority

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Razorpay (payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM=orders@yourdomain.com

# ── Frontend (set these as env vars in Render / Vercel, NOT in this file) ─────
# NEXT_PUBLIC_API_URL=https://varcha-backend.onrender.com   ← backend Render URL
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx           ← same as RAZORPAY_KEY_ID
# NEXT_PUBLIC_SITE_URL=https://varcha-frontend.onrender.com ← frontend Render URL
